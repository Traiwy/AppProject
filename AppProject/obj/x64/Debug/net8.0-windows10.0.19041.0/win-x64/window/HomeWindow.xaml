<Window
    x:Class="AppProject.HomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="1000" HorizontalAlignment="Stretch">
            
            <InfoBar x:ConnectionId='2' x:Name="AdmissionInfoBar"
                     IsOpen="True"
                     Severity="Informational"
                     Title="Приемная кампания 2026"
                     Message="Прием документов на бюджетную форму обучения продлится до 25 июля. Успейте подать оригиналы!"
                     IsClosable="False">
                <InfoBar.ActionButton>
                    <Button Content="График приема"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <TextBlock Text="Подано заявлений" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                    <TextBlock Text="1 240" Style="{StaticResource TitleLargeTextBlockStyle}" Foreground="{ThemeResource SystemAccentColor}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <TextBlock Text="Бюджетных мест" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                    <TextBlock Text="450" Style="{StaticResource TitleLargeTextBlockStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <TextBlock Text="Ваш средний балл" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                    <NumberBox x:ConnectionId='6' x:Name="ScoreInput" Value="0" SpinButtonPlacementMode="Inline" SmallChange="1" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <RelativePanel Background="{ThemeResource SystemControlBackgroundAccentBrush}" Padding="24" CornerRadius="12">
                <StackPanel x:ConnectionId='5' x:Name="ActionText">
                    <TextBlock Text="Готовы стать студентом?" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="White"/>
                    <TextBlock Text="Начните путь к карьере мечты прямо сейчас." Foreground="White" Opacity="0.8"/>
                </StackPanel>
                
                <Button Content="Подать заявление" 
                        Style="{StaticResource AccentButtonStyle}"
                        Background="White" Foreground="Black"
                        Padding="24,12" FontSize="16" FontWeight="SemiBold"
                        RelativePanel.AlignRightWithPanel="True"
                        RelativePanel.AlignVerticalCenterWithPanel="True"/>
            </RelativePanel>

            <StackPanel Spacing="12">
                <TextBlock Text="Новости и объявления" Style="{StaticResource SubsetHeaderTextBlockStyle}"/>
                
                <ListView x:ConnectionId='3' x:Name="NewsListView" 
                          SelectionMode="None"
                          IsItemClickEnabled="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,12" ColumnDefinitions="Auto, *">
                                <FontIcon Glyph="&#xE91F;" Margin="0,0,16,0" Foreground="{ThemeResource SystemAccentColor}"/>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Date}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    <TextBlock Text="{Binding Summary}" MaxLines="2" TextTrimming="CharacterEllipsis" Opacity="0.7"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>

